# Copy this file to .env and adjust values for your local environment.
# Do not commit .env because it may contain secrets.

# Default mode: call an OpenAI-compatible Chat Completions endpoint.
PYDANTIC_AGENT_MODEL_PROVIDER=openai-compatible
PYDANTIC_AGENT_MODEL=gpt-5.2

# Structured output mode:
# - auto: try native, then tool, then prompted output.
# - native: use model-native structured outputs / JSON schema.
# - tool: use tool calling for Pydantic-validated results.
# - prompted: ask for parseable JSON in the prompt; widest compatibility.
PYDANTIC_AGENT_STRUCTURED_OUTPUT_MODE=auto

# Per-attempt timeout for LLM requests.
PYDANTIC_AGENT_REQUEST_TIMEOUT_SECONDS=7

# Maximum Pydantic AI retries for model, output, and tool failures.
PYDANTIC_AGENT_MODEL_RETRIES=3

# Leave base URL empty to use the OpenAI SDK default, or set a compatible endpoint:
# PYDANTIC_AGENT_OPENAI_BASE_URL=https://api.openai.com/v1
# PYDANTIC_AGENT_OPENAI_BASE_URL=https://api.deepseek.com/v1
# PYDANTIC_AGENT_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# PYDANTIC_AGENT_OPENAI_BASE_URL=http://localhost:11434/v1
PYDANTIC_AGENT_OPENAI_BASE_URL=

# You can also use OPENAI_API_KEY directly; this prefixed key wins when set.
# PYDANTIC_AGENT_OPENAI_API_KEY=sk-...

# Advanced mode: pass the model string straight to Pydantic AI.
# PYDANTIC_AGENT_MODEL_PROVIDER=pydantic-ai
# PYDANTIC_AGENT_MODEL=openai:gpt-5.2

# Local deterministic mode. Set to true to avoid calling any model.
PYDANTIC_AGENT_MOCK=false
